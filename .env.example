# Zoho Books API Credentials
# Get these from: https://api-console.zoho.com/

ZOHO_ORGANIZATION_ID=your_organization_id_here
ZOHO_ACCESS_TOKEN=your_access_token_here

# Optional: Refresh token for auto-renewal (recommended for production)
# ZOHO_CLIENT_ID=your_client_id
# ZOHO_CLIENT_SECRET=your_client_secret
# ZOHO_REFRESH_TOKEN=your_refresh_token

# Server Configuration
PORT=3000

# ============================================================================
# HOW TO GET ZOHO CREDENTIALS:
# ============================================================================
#
# 1. Go to https://api-console.zoho.com/
# 2. Click "Add Client" → "Self Client"
# 3. Note down Client ID and Client Secret
# 4. Generate access token with scope: ZohoBooks.fullaccess.all
# 5. Get Organization ID from Zoho Books settings
#
# For production (auto-renewing tokens):
# Use the refresh token flow - see Zoho OAuth docs
# ============================================================================
